// src/screens/ScanScreen.tsx
import React, { useState, useEffect } from 'react';
import { View, Text, StyleSheet, TouchableOpacity, Alert, Dimensions, Vibration } from 'react-native';
import { BarCodeScanner } from 'expo-barcode-scanner';
import * as Speech from 'expo-speech';
import * as Haptics from 'expo-haptics';
import { theme } from '../theme';

const { width } = Dimensions.get('window');

export default function ScanScreen() {
  const [scanned, setScanned] = useState(false);
  const [isOffline, setIsOffline] = useState(false);

  useEffect(() => {
    Speech.speak("Mở máy quét. Đưa mã vạch vào khung.", { language: 'vi' });
  }, []);

  const speak = (text: string) => {
    Speech.speak(text, { language: 'vi', pitch: 1.0, rate: 0.9 });
  };

  const handleBarCodeScanned = async ({ data }: any) => {
    if (scanned) return;
    
    setScanned(true);
    Vibration.vibrate([0, 200, 100, 200]); // Rung mạnh
    Haptics.notificationAsync(Haptics.NotificationFeedbackType.Success);

    speak(`Đã quét thành công. Mã đơn hàng ${data}`);

    Alert.alert(
      "✅ QUÉT THÀNH CÔNG!",
      `Mã đơn: ${data}\n\nTrạng thái: Đang cập nhật...`,
      [
        { 
          text: "✅ XÁC NHẬN & TIẾP TỤC", 
          onPress: () => {
            setScanned(false);
            speak("Sẵn sàng quét đơn hàng tiếp theo");
          }
        }
      ],
      { cancelable: false }
    );
  };

  return (
    <View style={styles.container}>
      <Text style={styles.header}>MÁY QUÉT ĐƠN HÀNG</Text>
      <Text style={styles.subHeader}>Chú đưa mã vạch vào khung giữa màn hình</Text>

      <View style={styles.scannerContainer}>
        <BarCodeScanner
          onBarCodeScanned={scanned ? undefined : handleBarCodeScanned}
          style={styles.scanner}
        />
        
        <View style={styles.overlayFrame}>
          <Text style={styles.frameText}>KHUNG QUÉT</Text>
        </View>
      </View>

      {/* Nút bấm cực lớn */}
      <View style={styles.buttonArea}>
        <TouchableOpacity 
          style={styles.bigButton}
          onPress={() => {
            setScanned(false);
            speak("Đang quét lại");
          }}
        >
          <Text style={styles.buttonText}>📸 QUÉT LẠI</Text>
        </TouchableOpacity>

        <TouchableOpacity 
          style={[styles.bigButton, styles.completeBtn]}
          onPress={() => speak("Chuyến hàng đã hoàn thành. Nghỉ ngơi nhé chú!")}
        >
          <Text style={styles.buttonText}>✅ HOÀN THÀNH CHUYẾN</Text>
        </TouchableOpacity>
      </View>

      {isOffline && (
        <Text style={styles.offlineText}>⚠️ Đang ở chế độ Offline - Dữ liệu sẽ đồng bộ sau</Text>
      )}
    </View>
  );
}

